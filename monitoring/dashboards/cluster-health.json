      },
      "pluginVersion": "8.0.0",
      "targets": [
        {
          "expr": "up{job=\"kubernetes-nodes\"}",
          "format": "table",
          "instant": true,
          "interval": "",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "title": "Node Status",
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "job": true
            },
            "indexByName": {
              "Value": 1,
              "node": 0
            },
            "renameByName": {
              "Value": "Status",
              "node": "Node"
            }
          }
        }
      ],
      "type": "table"
    }
